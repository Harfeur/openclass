<!doctype html>
<html lang="fr">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Open Class</title>
    <script src="https://cdn.jsdelivr.net/npm/lemonadejs/dist/lemonade.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@calendarjs/ce/dist/index.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@calendarjs/ce/dist/style.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/lemonadejs/dist/lemonade.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@calendarjs/ce/dist/index.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@calendarjs/ce/dist/style.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/index.css" />
</head>

<body>

    <header>
        <nav class="navbar navbar-light bg-light">
            <a class="navbar-brand" href="http://localhost:3000/try">
                <img src="images/openclass-logo.png" width="30" height="30" class="d-inline-block align-top" alt="">
                OpenClass
            </a>
        </nav>
    </header>


    <div id="parent">
        <div id='schedule' style="height: 100%;"></div>
        <button id="inscription" type="button" class="btn btn-primary" data-bs-toggle="modal"
            data-bs-target="#exampleModal">
            S'inscrire
        </button>
    </div>





    <!-- Button trigger modal -->




    <!-- Modal -->
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="exampleModalLabel">Je veux être visité</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div id="alertes">

                </div>

                <form id="form_inscr" method="post">

                    <div class="modal-body">

                        <div class="mb-3">
                            <label for="matieres" class="form-label">Matière <span class="req">*</span></label>
                            <select id="matieres" class="form-select" required>
                                <option value="" selected disabled hidden>Choisisez</option>
                                <% for(var i=0; i<data_matiere.length ; i++) {%>
                                    <option value=<%=data_matiere[i].id %> >
                                        <%=data_matiere[i].matiere %>
                                    </option>
                                    <% } %>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="groupes" class="form-label">Groupe <span class="req">*</span></label>
                            <select id="groupes" class="form-select" required>
                                <option value="" selected disabled hidden>Choisisez</option>
                                <% for(var i=0; i<data_groupes.length; i++) {%>
                                    <option value=<%=data_groupes[i].id %> >
                                        <%=data_groupes[i].groupe %>
                                    </option>
                                    <% } %>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="date" class="form-label">Date <span class="req">*</span></label>
                            <input type="date" class="form-control" id="date" name="date" required>

                        </div>
                        <div class="mb-3">
                            <label for="heureDebut" class="form-label">Heure Debut <span class="req">*</span></label>
                            <input type="time" class="form-control" id="heureDebut" name="heureDebut" required>
                        </div>
                        <div class="mb-3">
                            <label for="heureFin" class="form-label">Heure Fin <span class="req">*</span></label>
                            <input type="time" class="form-control" id="heureFin" name="heureFin" required>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="radioDefault" id="reguliere"
                                onchange="reguilereE()">
                            <label class="form-check-label" for="reguliere">
                                Régulièrement
                            </label>
                        </div>

                        <div id="reguliereOptions">
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="semaineA" value="False">
                                <label class="form-check-label" for="semaineA">Semaine A</label>
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="semaineB">
                                <label class="form-check-label" for="semaineB">Semaine B</label>
                            </div>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="radioDefault" id="uneSeeulFois"
                                onchange="reguilereE()">
                            <label class="form-check-label" for="uneSeeulFois">
                                Une seule fois
                            </label>
                        </div>


                        <div class="mb-3">
                            <label for="nom" class="form-label">Votre Nom & Prénom <span class="req">*</span></label>
                            <input type="name" class="form-control" id="nom" aria-describedby="emailHelp" required>
                        </div>
                        <div class="mb-3">
                            <label for="courriel" class="form-label">Votre E-Mail <span class="req">*</span></label>
                            <input type="email" class="form-control" id="courriel" aria-describedby="emailHelp"
                                required>
                        </div>


                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button id="nouveau" type="submit" class="btn btn-primary">Inscrire</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
    <script src="/javascripts/index.js"></script>


    <footer>
        <a href="#">OpenClass</a> © 2026 by <a href="#">Daniel Hasan</a> is licensed
        under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a><img
            src="https://mirrors.creativecommons.org/presskit/icons/cc.svg" alt=""
            style="max-width: 1em;max-height:1em;margin-left: .2em;"><img
            src="https://mirrors.creativecommons.org/presskit/icons/by.svg" alt=""
            style="max-width: 1em;max-height:1em;margin-left: .2em;"><img
            src="https://mirrors.creativecommons.org/presskit/icons/nc.svg" alt=""
            style="max-width: 1em;max-height:1em;margin-left: .2em;"><img
            src="https://mirrors.creativecommons.org/presskit/icons/sa.svg" alt=""
            style="max-width: 1em;max-height:1em;margin-left: .2em;">
    </footer>

    <script>
        const { Schedule } = calendarjs;

        Schedule(document.getElementById('schedule'), {
            type: 'weekdays',
            weekly: true,
            validRange: ['08:00', '18:00'],
            readOnlyRange: ['08:00', '18:00'],
            overlap: true,
            data: [
                { guid: '1', title: 'Morning Meeting', weekday: 1, start: '08:00', end: '09:00', color: '#3498db', readonly: false },

                { guid: '2', title: 'Lunch Break', weekday: 1, start: '12:00', end: '13:00', color: '#95a5a6', readonly: true, description: "Test description" },
                { guid: '3', title: 'Lunch Break', weekday: 2, start: '12:00', end: '13:00', color: '#95a5a6', readonly: true },
                { guid: '4', title: 'Lunch Break', weekday: 3, start: '12:00', end: '13:00', color: '#95a5a6', readonly: true },
                { guid: '5', title: 'Lunch Break', weekday: 4, start: '12:00', end: '13:00', color: '#95a5a6', readonly: true },
                { guid: '6', title: 'Lunch Break', weekday: 5, start: '12:00', end: '13:00', color: '#95a5a6', readonly: true },

                { guid: '7', title: 'Project Work', weekday: 2, start: '10:30', end: '12:00', color: '#2ecc71', visible: true },
                { guid: '8', title: 'Project Work', weekday: 2, start: '10:00', end: '11:00', color: '#2ecc71', visible: true }
            ]
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>